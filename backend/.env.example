# Copy this file to .env and fill in real values. Never commit .env itself.

# Which free provider to use: "groq" (default, recommended) or "gemini".
GENAI_PROVIDER=groq

# Only the key for whichever provider you picked above is required.
# Groq:   free, no credit card -> https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
# Gemini: free, no credit card -> https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: override the default model for your chosen provider
# (Groq default: openai/gpt-oss-20b · Gemini default: gemini-flash-latest)
GENAI_MODEL=

# Optional server settings
PORT=3000
ALLOWED_ORIGIN=http://localhost:3000
TRUST_PROXY=0
